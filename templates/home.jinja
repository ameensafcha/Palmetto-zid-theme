{% extends "layout.jinja" %}
{% block content %}
<style>
  .catalog-head{
    display:grid; grid-template-columns: 1fr auto 1fr; gap:14px;
    align-items:end;
    padding: 16px 14px 8px;
    border-top: 1px solid var(--lo); border-bottom:1px solid var(--hi);
  }
  .catalog-head .l, .catalog-head .r{
    height: 1px; background: repeating-linear-gradient(90deg,#000 0 4px, transparent 4px 8px);
    margin-bottom: 14px;
  }
  .catalog-head .center{ text-align:center; }
  .catalog-head h2{
    margin:0; font-family:"Times New Roman",serif; font-size:34px; font-weight:700; letter-spacing:.5px;
  }
  .catalog-head .sub{ font-style:italic; font-family:"Times New Roman",serif; font-size:15px; margin-top:4px;}
  .catalog-head .sub-ar{ font-size:18px; margin-top:2px;}

  .product-grid{
    display:grid; grid-template-columns: repeat(4, 1fr); gap:12px;
    padding: 14px;
  }
  .card{
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
  }
  .card .titlebar{ height:20px; font-size:11px; }
  .card .titlebar .t-title{ font-size:11px;}
  .card .img{
    aspect-ratio: 1/1;
    margin: 6px;
    background:var(--paper);
    border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    position:relative;
    overflow:hidden;
  }
  .card .img .ph{
    position:absolute; inset:0;
    background-image: repeating-linear-gradient(135deg, #efe9d2 0 8px, #f6f1de 8px 16px);
  }
  .card .img .ph::after{
    content: attr(data-label);
    position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);
    font-family:"Courier New",monospace; font-size:10px; color:#5a5037; letter-spacing:1px;
    background: rgba(255,255,247,.85); padding: 2px 6px; border:1px dashed #5a5037;
  }
  .card .meta{ padding: 4px 8px 8px; }
  .card .meta .row{ display:flex; align-items:baseline; justify-content:space-between; gap:6px;}
  .card .meta .name{ font-family:"Times New Roman",serif; font-size:15px; font-weight:700;}
  .card .meta .price{ font-family:"Courier New",monospace; font-weight:700; font-size:13px;}
  .card .meta .color{ font-family:"Times New Roman",serif; font-style:italic; font-size:13px; color:#222;}
  .card .meta .desc{ font-family:"Times New Roman",serif; font-size:11px; color:#3a3a3a; margin-top:4px; line-height:1.3; }
  .card .meta .desc.ar{ font-size:12px; }
  .card .actions{
    display:flex; gap:6px; padding: 4px 8px 8px;
  }

  .badges{
    display:flex; gap:14px; justify-content:center;
    padding: 10px 14px 16px;
    border-top:1px solid var(--hi);
  }
  .seal{
    width: 200px; height: 110px;
    flex: 0 0 auto;
    border:3px double currentColor;
    border-radius: 50%/55%;
    display:grid; place-items:center;
    text-align:center;
    padding: 6px 10px;
    font-family:"Times New Roman", serif;
    font-weight:700;
    line-height:1.1;
    transform: rotate(-3deg);
    background: rgba(255,255,255,.55);
  }
  .seal.red{ color:var(--red);}
  .seal.green{ color:var(--green); transform: rotate(2deg);}
  .seal .big{ font-size:14px; letter-spacing:1px;}
  .seal .small{ font-size:11px; font-weight:400; font-style:italic; margin-top:3px; color:inherit; }
  .seal .ar{ font-size:12px; font-weight:700; font-style:normal; margin-top:2px; line-height:1.2;}

  .panel{
    background: var(--paper);
    border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    margin: 10px;
    padding: 22px 26px;
  }
  .panel p{ font-family:"Times New Roman",serif; font-size:15px; line-height:1.6; margin: 0 0 10px;}
  .panel .signoff{ font-style:italic; color:#444; margin-top: 14px;}
  .two-col{ display:grid; grid-template-columns: 1fr 1fr; gap: 26px; align-items:start;}
  .two-col > .col-ar{ border-left: 1px dashed #b0a890; padding-left: 22px;}

  .palm-archive .list{
    font-family: "Courier New", monospace;
    font-size: 14px;
    line-height: 1.9;
    padding: 6px 0 6px 8px;
  }
  .palm-archive .list .num{ color:#000; font-weight:700;}
  .palm-archive .list .dots{ color:#888;}
  .palm-archive .photos{
    display:grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
    margin-top: 14px;
  }
  .palm-archive .photo{
    aspect-ratio: 4/5;
    background:
      linear-gradient(180deg, rgba(0,0,0,.05), rgba(0,0,0,0) 30%),
      repeating-linear-gradient(180deg, #d9cfa6 0 8px, #cdc193 8px 16px);
    border:1px solid #000;
    box-shadow: inset 0 0 0 5px var(--paper);
    position:relative;
    display:grid; place-items:end stretch;
  }
  .palm-archive .photo .cap{
    margin: 0 8px 8px;
    background: var(--paper);
    border:1px solid #000;
    padding: 4px 6px;
    font-family:"Courier New",monospace; font-size:11px;
    display:flex; justify-content:space-between; gap:6px;
  }
  .palm-archive .archive-link{
    margin-top: 14px;
    text-align:center;
    font-family:"Courier New",monospace; font-size: 14px;
  }
  .palm-archive .archive-link a{
    text-decoration:underline; font-weight:700;
  }

  .size-guide .grid{ display:grid; grid-template-columns: 220px 1fr; gap: 22px; align-items:start;}
  .size-guide .legend{
    font-family:"Times New Roman",serif; font-style:italic; font-size:13px;
    margin-top: 8px; color:#333;
  }
  table.size-table{
    width:100%; border-collapse: collapse;
    font-family:"Times New Roman", serif; font-size:14px;
  }
  table.size-table th, table.size-table td{
    border:1px solid #000;
    padding: 6px 10px;
    text-align:left;
    background:#fff;
  }
  table.size-table thead th{
    background: var(--chrome);
    font-family:"Tahoma",sans-serif; font-size:11px;
    text-transform: uppercase; letter-spacing:.5px;
  }
  table.size-table td.size{ font-weight:700; font-family:"Courier New", monospace; width:60px;}
  table.size-table .imp{ color:#666; font-size:12px;}
  .size-guide .footnote{ font-size:12px; color:#444; font-style:italic; margin-top:6px;}

  .contact-grid{ display:grid; grid-template-columns: 1fr 1fr; gap:24px; }
  .contact-grid .field-row{
    display:grid; grid-template-columns: 110px 1fr; gap:10px;
    margin-bottom: 8px;
    align-items:center;
  }
  .contact-grid .lbl{
    font-family:"Tahoma",sans-serif; font-size:11px; text-align:right;
  }
  .contact-grid .val{
    background:#fff; border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    padding: 4px 8px; font-family:"Courier New", monospace; font-size:13px;
  }

  .ship-row{
    display:grid; grid-template-columns: 110px 1fr; gap:14px;
    align-items:start; margin-bottom:14px;
  }
  .ship-row .tag{
    font-family:"Tahoma",sans-serif; font-size:11px; font-weight:700;
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    padding: 4px 6px; text-align:center;
  }

  @media (max-width: 760px) {
    .two-col{ grid-template-columns: 1fr; }
    .two-col > .col-ar{ border-left: none; padding-left: 0; border-top: 1px dashed #b0a890; padding-top: 18px; }
    .product-grid{ grid-template-columns: repeat(2, 1fr); }
    .badges{ flex-direction:column; align-items:center; }
  }
</style>

