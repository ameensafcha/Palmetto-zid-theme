<!DOCTYPE html>
<html dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ store.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ 'style.css' | asset_url }}">
  <style>
    :root {
      --chrome: #c0c0c0;
      --chrome-2: #bdbdbd;
      --hi: #ffffff;
      --hi-2: #dfdfdf;
      --lo: #808080;
      --lo-2: #000000;
      --tb-1: #000080;
      --tb-2: #1084d0;
      --tb-inactive-1: #7b7b7b;
      --tb-inactive-2: #a0a0a0;
      --paper: #fffef7;
      --ink: #101010;
      --link: #0000ee;
      --link-v: #551a8b;
      --warn-yellow: #ffff00;
      --warn-yellow-2: #fff170;
      --red: #b00000;
      --green: #0a7a2a;
      --desktop: #008080;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    html, body { margin: 0; padding: 0; }
    section[id] { scroll-margin-top: 16px; }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
    }
    body {
      background: #0f8a85 url('{{ "bg-floral.png" | asset_url }}') repeat;
      background-size: 480px auto;
      font-family: "Tahoma","MS Sans Serif",Geneva,sans-serif;
      font-size: 11px;
      color: #000;
      min-height: 100vh;
      padding-bottom: 32px;
    }
    a { color: var(--link); }
    a:visited { color: var(--link-v); }
    section.win{ margin-top: 28px; }
    section.win:first-of-type{ margin-top: 0; }
    .ar{ direction:rtl; text-align:right; font-family: "Amiri", "Traditional Arabic", "Times New Roman", serif; font-size:18px; line-height:1.85; }
    .ar.small{ font-size:14px; }
    .container { max-width: 960px; margin: 0 auto; width: 96vw; }
  </style>
  <script>
    window.i18n = {
      addToCart: "{{ _('Add To Cart') }}",
      continueShopping: "{{ _('Continue Shopping') }}",
      cartEmpty: "{{ _('Your cart is empty') }}"
    };
  </script>
  {% vitrin_head %}
</head>
<body>
  {% vitrin_body %}
  {% include 'header.jinja' %}
  <main>{% block content %}{% endblock %}</main>
  {% include 'footer.jinja' %}
  {% include 'components/cart-sidebar.jinja' %}
  <script src="{{ 'main.js' | asset_url }}"></script>
  {% include 'components/cart-script.jinja' %}
</body>
</html>