<script>
// ── Global cart API functions ──

function loadCart(){
  var body = document.getElementById('cart-body');
  var footer = document.getElementById('cart-footer');
  var totalEl = document.getElementById('cart-total');
  var cartBtn = document.getElementById('cart-btn');
  var badge = cartBtn && cartBtn.querySelector('.badge');
  return fetch('/api/v1/cart', {
    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(function(r){ if(!r.ok) throw new Error('Status: '+r.status); return r.json(); })
  .then(function(c){
    var items = c.products || [];
    var count = 0;
    for(var i=0;i<items.length;i++) count += (items[i].quantity || 1);

    if(badge){
      badge.textContent = count;
      badge.style.display = count ? 'inline-block' : 'none';
    }

    if(!items.length){
      body.innerHTML = '<div class="cart-empty">' + (window.i18n.cartEmpty || 'Your cart is empty.') + '</div>';
      if(footer) footer.style.display = 'none';
      return;
    }

    var h = '';
    for(var i=0;i<items.length;i++){
      var it = items[i];
      var img = '';
      if(it.images && it.images[0]){
        img = (it.images[0].thumbs && it.images[0].thumbs.small) || it.images[0].origin || '';
      }
      var imgH = img
        ? '<img src="'+img+'" alt="'+it.name+'" style="display:block;width:100%;height:100%;object-fit:cover;">'
        : (it.name||'?').toLowerCase().replace(/\s/g,'-').substring(0,10);

      h += '<div class="cart-item" data-key="'+it.id+'">'+
        '<div class="ci-img">'+imgH+'</div>'+
        '<div><div class="ci-name">'+it.name+'</div></div>'+
        '<div class="ci-price">'+(it.total_string||'')+'</div>'+
        '<div class="ci-qty">'+
          '<button class="qty-btn" onclick="updateCartItem('+it.id+','+(it.quantity-1)+',this)"'+(it.quantity<=1?' disabled':'')+'>−</button>'+
          '<span class="qty-num">'+it.quantity+'</span>'+
          '<button class="qty-btn" onclick="updateCartItem('+it.id+','+(it.quantity+1)+',this)">+</button>'+
        '</div>'+
        '<button class="ci-remove" onclick="removeCartItem('+it.id+',this)">✕</button>'+
      '</div>';
    }
    body.innerHTML = h;
    if(totalEl) totalEl.textContent = (c.total && c.total.value_string) || '';
    if(footer) footer.style.display = 'flex';
  })
  .catch(function(e){ console.error('[Cart] Load error:', e); });
}

async function addToCart(productId, quantity = 1, btn = null) {
  if(btn){ btn.disabled = true; btn.textContent = 'Adding...'; }
  try {
    const response = await fetch('/api/v1/cart/items', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ product_id: productId, quantity: quantity })
    });
    if(!response.ok) throw new Error('Status: ' + response.status);
    await loadCart();
    openCart();
    if(btn){
      btn.textContent = 'Added! ✓';
      btn.style.backgroundColor = '#374151';
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = window.i18n.addToCart || 'Add To Cart';
        btn.style.backgroundColor = '';
      }, 2000);
    }
  } catch(err) {
    console.error('[Cart] Add error:', err);
    openCart();
    if(btn){
      btn.disabled = false;
      btn.textContent = 'Failed — Retry';
      btn.style.backgroundColor = '#ef4444';
      setTimeout(() => {
        btn.textContent = window.i18n.addToCart || 'Add To Cart';
        btn.style.backgroundColor = '';
      }, 2000);
    }
  }
}

function updateCartItem(id, nq, btn){
  if(nq < 1){ removeCartItem(id); return; }
  if(btn) btn.disabled = true;
  var fd = new URLSearchParams();
  fd.append('quantity', nq);
  fetch('/api/v1/cart/items/'+id, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    body: fd.toString()
  })
  .then(function(r){ if(!r.ok) throw new Error('Status: '+r.status); })
  .then(function(){ loadCart(); })
  .catch(function(e){ console.error('[Cart] Update error:', e); if(btn) btn.disabled = false; });
}

function removeCartItem(id, btn){
  if(btn) btn.disabled = true;
  fetch('/api/v1/cart/items/'+id, {
    method: 'DELETE',
    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(function(r){ if(!r.ok) throw new Error('Status: '+r.status); })
  .then(function(){ loadCart(); })
  .catch(function(e){ console.error('[Cart] Remove error:', e); if(btn) btn.disabled = false; });
}

function openCart(){
  var d = document.getElementById('cart-drawer');
  var o = document.getElementById('cart-overlay');
  if(d) d.classList.add('open');
  if(o) o.classList.add('open');
}

function closeCart(){
  var d = document.getElementById('cart-drawer');
  var o = document.getElementById('cart-overlay');
  if(d) d.classList.remove('open');
  if(o) o.classList.remove('open');
}

// ── DOM init ──
(function(){
  document.addEventListener('click', function(e){
    var btn = e.target.closest('[data-add]');
    if(!btn) return;
    var card = btn.closest('.card');
    if(!card) return;
    var pid = card.getAttribute('data-product');
    if(!pid) return;
    e.preventDefault();
    addToCart(pid, 1, btn);
  });
  document.addEventListener('click', function(e){
    var btn = e.target.closest('[data-add-variant]');
    if(!btn) return;
    var card = btn.closest('.card');
    if(!card) return;
    var vid = card.dataset.selectedVariant;
    if(!vid) return;
    e.preventDefault();
    addToCart(vid, 1, btn);
  });
  document.getElementById('cart-close').addEventListener('click', closeCart);
  document.getElementById('cart-continue') && document.getElementById('cart-continue').addEventListener('click', closeCart);
  var overlay = document.getElementById('cart-overlay');
  if(overlay) overlay.addEventListener('click', closeCart);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeCart(); });
  var cartBtn = document.getElementById('cart-btn');
  if(cartBtn) cartBtn.addEventListener('click', openCart);
  loadCart();
})();
</script>
