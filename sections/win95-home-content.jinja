<section class="win" id="shipping">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="3" width="6" height="4" fill="#fff" stroke="#000"/><circle cx="3" cy="8" r="1" fill="#000"/><circle cx="7" cy="8" r="1" fill="#000"/></svg></span>
    <span class="t-title"><span>{{ settings.shipping_title_en | default("Shipping") }}</span><span class="ar">{{ settings.shipping_title_ar | default("الشحن") }}</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        {% if settings.shipping_intro_en is defined and settings.shipping_intro_en %}<p style="margin-top:0;">{{ settings.shipping_intro_en }}</p>{% endif %}
        <div class="ship-row">
          <div class="tag">{{ settings.shipping_sa_tag_en | default("Saudi Arabia") }}</div>
          <div>{{ settings.shipping_sa_content_en | default('Orders ship within <b>1\u20132 business days</b> and arrive within <b>2\u20135 business days</b> depending on your city. <b>Free domestic shipping</b> on orders over <b>350 SAR</b>.') }}</div>
        </div>
        <div class="ship-row">
          <div class="tag">{{ settings.shipping_intl_tag_en | default("International") }}</div>
          <div>{{ settings.shipping_intl_content_en | default('Rates and delivery times vary by destination and shipping method. Both are calculated at checkout, so you\'ll see the full cost before you pay.') }}</div>
        </div>
        {% if settings.shipping_closing_en is defined and settings.shipping_closing_en %}<p>{{ settings.shipping_closing_en }}</p>{% endif %}
        {% if settings.shipping_signoff_en is defined and settings.shipping_signoff_en %}<p class="signoff">{{ settings.shipping_signoff_en }}</p>{% endif %}
      </div>
      <div class="col-ar ar" style="font-size:15px; line-height:1.5;">
        {% if settings.shipping_intro_ar is defined and settings.shipping_intro_ar %}<p style="margin-top:0;">{{ settings.shipping_intro_ar }}</p>{% endif %}
        <div class="ship-row" style="grid-template-columns: 130px 1fr; direction:rtl;">
          <div class="tag" style="font-family:'Amiri',serif; font-size:13px; line-height:1.2; font-weight:400;">{{ settings.shipping_sa_tag_ar | default("\u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629") }}</div>
          <div style="font-size:15px; line-height:1.5; font-weight:400;">{{ settings.shipping_sa_content_ar | default("\u062a\u064f\u0634\u062d\u0646 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u062e\u0644\u0627\u0644 \u064a\u0648\u0645 \u0625\u0644\u0649 \u064a\u0648\u0645\u064e\u064a \u0639\u0645\u0644\u060c \u0648\u062a\u0635\u0644 \u062e\u0644\u0627\u0644 \u064a\u0648\u0645\u064e\u064a\u0646 \u0625\u0644\u0649 \u062e\u0645\u0633\u0629 \u0623\u064a\u0627\u0645 \u0639\u0645\u0644 \u0628\u062d\u0633\u0628 \u0645\u062f\u064a\u0646\u062a\u0643. \u0627\u0644\u0634\u062d\u0646 \u0627\u0644\u062f\u0627\u062e\u0644\u064a \u0645\u062c\u0651\u0627\u0646\u064a \u0644\u0644\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u062a\u062c\u0627\u0648\u0632 \u0663\u0665\u0660 \u0631\u064a\u0627\u0644.") }}</div>
        </div>
        <div class="ship-row" style="grid-template-columns: 130px 1fr; direction:rtl;">
          <div class="tag" style="font-family:'Amiri',serif; font-size:13px; line-height:1.2; font-weight:400;">{{ settings.shipping_intl_tag_ar | default("\u0627\u0644\u0634\u062d\u0646 \u0627\u0644\u062f\u0648\u0644\u064a") }}</div>
          <div style="font-size:15px; line-height:1.5; font-weight:400;">{{ settings.shipping_intl_content_ar | default("\u062a\u062e\u062a\u0644\u0641 \u0627\u0644\u0631\u0633\u0648\u0645 \u0648\u0623\u0648\u0642\u0627\u062a \u0627\u0644\u062a\u0648\u0635\u064a\u0644 \u0628\u062d\u0633\u0628 \u0627\u0644\u0648\u062c\u0647\u0629 \u0648\u0637\u0631\u064a\u0642\u0629 \u0627\u0644\u0634\u062d\u0646. \u062a\u064f\u062d\u062a\u0633\u0628 \u062c\u0645\u064a\u0639\u0647\u0627 \u0639\u0646\u062f \u0625\u062a\u0645\u0627\u0645 \u0627\u0644\u0637\u0644\u0628\u060c \u0644\u062a\u0643\u0648\u0646 \u0627\u0644\u0643\u0644\u0641\u0629 \u0643\u0627\u0645\u0644\u0629\u064b \u0648\u0627\u0636\u062d\u0629\u064b \u0642\u0628\u0644 \u0627\u0644\u062f\u0641\u0639.") }}</div>
        </div>
        {% if settings.shipping_closing_ar is defined and settings.shipping_closing_ar %}<p style="font-weight:400;">{{ settings.shipping_closing_ar }}</p>{% endif %}
        {% if settings.shipping_signoff_ar is defined and settings.shipping_signoff_ar %}<p class="signoff" style="font-style:italic; font-weight:400;">{{ settings.shipping_signoff_ar }}</p>{% endif %}
      </div>
    </div>
  </div>
</section>

<!-- Returns -->
