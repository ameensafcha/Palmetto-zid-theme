{% if settings.show is defined %}
  {% set is_shown = settings.show %}
{% else %}
  {% set is_shown = true %}
{% endif %}
{% if is_shown %}
<style>
  .panel{
    background: var(--paper);
    border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    margin: 10px;
    padding: 22px 26px;
  }
  .panel h3{
    margin: 0 0 10px;
    font-family: "Times New Roman", serif;
    font-size: 22px; font-weight:700;
  }
  .panel h3 .ar{ font-size: 18px; font-style:italic; opacity:.7; margin-left:8px;}
  .panel p{ font-family:"Times New Roman",serif; font-size:15px; line-height:1.6; margin: 0 0 10px;}
  .panel .signoff{ font-style:italic; color:#444; margin-top: 14px;}
  .two-col{ display:grid; grid-template-columns: 1fr 1fr; gap: 26px; align-items:start;}
  .two-col > .col-ar{ border-left: 1px dashed #b0a890; padding-left: 22px;}

  .palm-archive .list{
    font-family: "Courier New", monospace;
    font-size: 14px;
    line-height: 1.9;
    padding: 6px 0 6px 8px;
  }
  .palm-archive .list .num{ color:#000; font-weight:700;}
  .palm-archive .list .dots{ color:#888;}
  .palm-archive .photos{
    display:grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
    margin-top: 14px;
  }
  .palm-archive .photo{
    aspect-ratio: 4/5;
    background:
      linear-gradient(180deg, rgba(0,0,0,.05), rgba(0,0,0,0) 30%),
      repeating-linear-gradient(180deg, #d9cfa6 0 8px, #cdc193 8px 16px);
    border:1px solid #000;
    box-shadow: inset 0 0 0 5px var(--paper);
    position:relative;
    display:grid; place-items:end stretch;
  }
  .palm-archive .photo .cap{
    margin: 0 8px 8px;
    background: var(--paper);
    border:1px solid #000;
    padding: 4px 6px;
    font-family:"Courier New",monospace; font-size:11px;
    display:flex; justify-content:space-between; gap:6px;
  }
  .palm-archive .archive-link{
    margin-top: 14px;
    text-align:center;
    font-family:"Courier New",monospace; font-size: 14px;
  }
  .palm-archive .archive-link a{
    text-decoration:underline; font-weight:700;
  }

  .size-guide .grid{ display:grid; grid-template-columns: 220px 1fr; gap: 22px; align-items:start;}
  .size-guide .legend{
    font-family:"Times New Roman",serif; font-style:italic; font-size:13px;
    margin-top: 8px; color:#333;
  }
  table.size-table{
    width:100%; border-collapse: collapse;
    font-family:"Times New Roman", serif; font-size:14px;
  }
  table.size-table th, table.size-table td{
    border:1px solid #000;
    padding: 6px 10px;
    text-align:left;
    background:#fff;
  }
  table.size-table thead th{
    background: var(--chrome);
    font-family:"Tahoma",sans-serif; font-size:11px;
    text-transform: uppercase; letter-spacing:.5px;
  }
  table.size-table td.size{ font-weight:700; font-family:"Courier New", monospace; width:60px;}
  table.size-table .imp{ color:#666; font-size:12px;}
  .size-guide .footnote{ font-size:12px; color:#444; font-style:italic; margin-top:6px;}

  .contact-grid{ display:grid; grid-template-columns: 1fr 1fr; gap:24px; }
  .contact-grid .field-row{
    display:grid; grid-template-columns: 110px 1fr; gap:10px;
    margin-bottom: 8px;
    align-items:center;
  }
  .contact-grid .lbl{
    font-family:"Tahoma",sans-serif; font-size:11px; text-align:right;
  }
  .contact-grid .val{
    background:#fff; border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    padding: 4px 8px; font-family:"Courier New", monospace; font-size:13px;
  }

  .ship-row{
    display:grid; grid-template-columns: 110px 1fr; gap:14px;
    align-items:start; margin-bottom:14px;
  }
  .ship-row .tag{
    font-family:"Tahoma",sans-serif; font-size:11px; font-weight:700;
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    padding: 4px 6px; text-align:center;
  }

  .carpets-grid{
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-top: 22px;
  }
  .carpet-card{
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
    display:flex; flex-direction:column;
    min-width: 0;
  }
  .carpet-card > .titlebar{
    height: 22px; padding: 0 4px 0 6px;
    background: linear-gradient(90deg, #7d2a2a, #b85a3b);
    color:#fff; font-weight:700; font-size:11px;
    display:flex; align-items:center; gap:4px;
    flex-shrink:0;
  }
  .carpet-card > .titlebar .t-title{ flex:1; padding:0 4px; }
  .carpet-card > .titlebar .tb-btn{
    width:16px; height:16px; display:inline-flex; align-items:center; justify-content:center;
    background:var(--chrome); color:#000; font-size:10px;
    border-style:solid; border-width:1px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
  }
  .carpet-card .img{
    position:relative;
    aspect-ratio: 3/4;
    margin: 4px;
    background:#fffef7;
    border-style:solid; border-width:2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    overflow:hidden;
    cursor: zoom-in;
  }
  .carpet-card .img img.prod-img{
    width:100%; height:100%; object-fit: cover;
    display:block;
  }
  .carpet-card .img .index-badge{
    display: none;
  }
  .carpet-card .body{
    padding: 8px 10px 12px;
    display:flex; flex-direction:column; gap:6px;
    flex:1;
  }
  .carpet-card .head{
    display:flex; justify-content:space-between; align-items:baseline;
    gap:6px; flex-wrap:wrap;
    border-bottom: 1px dashed #8a7e62;
    padding-bottom:4px;
  }
  .carpet-card .head .name{
    font-family: "Times New Roman", serif; font-size: 15px; font-weight: 700; color:#101010;
  }
  .carpet-card .head .dim{
    font-family:"Courier New", monospace; font-size:10px; color:#5a5037;
  }
  .carpet-card .desc-en{
    margin:0;
    font-family: "Times New Roman", serif; font-size: 12px; font-style: italic; line-height:1.4; color:#1a1a1a;
  }
  .carpet-card .desc-ar{
    margin:0;
    direction:rtl; text-align:right;
    font-family: "Amiri", serif; font-size: 13px; line-height:1.55; color:#1a1a1a;
    border-top: 1px dotted #b0a890; padding-top:4px;
  }
  .carpet-card.pending .img{
    background: repeating-linear-gradient(135deg,#c8b88a 0 8px,#b5a274 8px 16px) !important;
  }
  .carpet-card .img .nav-arrow{
    position:absolute; top:50%; transform: translateY(-50%);
    width:22px; height:32px;
    display:grid; place-items:center;
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
    color:#000; font-family:"Tahoma",sans-serif; font-size:14px; font-weight:700;
    cursor:default;
    user-select:none;
    line-height:1;
    opacity:.92;
  }
  .carpet-card .img .nav-arrow:hover{ opacity:1; }
  .carpet-card .img .nav-arrow:active{
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    box-shadow: inset 1px 1px 0 var(--lo-2), inset -1px -1px 0 var(--hi-2);
  }
  .carpet-card .img .nav-arrow.prev{ left:4px; }
  .carpet-card .img .nav-arrow.next{ right:4px; }
  .carpet-card .img .view-count{
    position:absolute; left:4px; bottom:4px;
    background: rgba(0,0,0,.65); color:#fff;
    font-family:"Tahoma",sans-serif; font-size:10px;
    padding: 1px 5px;
    pointer-events:none;
  }
  .carpet-card .img .zoom-hint{
    position:absolute; right:4px; bottom:4px;
    background: rgba(0,0,0,.65); color:#fff;
    font-family:"Tahoma",sans-serif; font-size:10px;
    padding: 1px 5px;
    pointer-events:none;
    opacity:0; transition: opacity .12s;
  }
  .carpet-card .img:hover .zoom-hint{ opacity:1; }
  .carpets-bottom-row{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 14px;
  }
  .carpet-card.wide .body-row{
    display:grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 0;
  }
  .carpet-card.wide .img{
    aspect-ratio: 5/4;
    margin: 4px 2px 4px 4px;
  }
  .carpet-card.wide .body{
    padding: 10px 12px 14px;
  }
  @media (max-width: 880px){
    .carpets-bottom-row{ grid-template-columns: 1fr; }
  }
  @media (max-width: 720px){
    .carpet-card.wide .body-row{ grid-template-columns: 1fr; }
  }
  .ornaments{
    display:flex; gap:36px; justify-content:center; align-items:center;
    flex-wrap:wrap;
  }

  @media (max-width: 760px) {
    .panel{ padding: 18px 14px; margin: 8px;}
    .two-col{ grid-template-columns: 1fr; gap:18px;}
    .two-col > .col-ar{ border-left: none; padding-left: 0; border-top: 1px dashed #b0a890; padding-top: 14px; }
    .size-guide .grid{ grid-template-columns: 1fr; gap:18px;}
    .palm-archive .photos{ grid-template-columns: repeat(2, 1fr); }
    .contact-grid{ grid-template-columns: 1fr; gap:14px;}
    .ship-row{ grid-template-columns: 100px 1fr; gap:10px;}
    .ornaments{ gap:18px;}
    table.size-table th, table.size-table td{ padding: 4px 6px; font-size:13px;}
  }
  @media (max-width: 480px) {
    .palm-archive .photos{ grid-template-columns: 1fr;}
    .ship-row{ grid-template-columns: 1fr; }
    .ship-row .tag{ justify-self:start; }
    .carpets-grid{ grid-template-columns: 1fr;}
  }
  .modal-veil{
    position:fixed; inset:0;
    background: rgba(0,0,0,.25);
    display:none; place-items:center;
    z-index: 50;
  }
  .modal-veil.open{ display:grid; }
  .modal{
    width: 360px; max-width: 92vw;
    background:var(--chrome);
    border-style:solid; border-width:2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo), 4px 4px 0 rgba(0,0,0,.3);
  }
  .modal .body-pad{ padding: 18px; display:flex; gap:14px; align-items:flex-start;}
  .modal .icon-warn{ width:40px; height:40px; flex:0 0 40px; border-radius:50%; background:var(--warn-yellow); border:2px solid #000; display:grid; place-items:center; color:#000; font-family:"Times New Roman",serif; font-weight:900; font-size:30px; line-height:1; }
  .modal .msg{ font-family:"Tahoma",sans-serif; font-size:12px; line-height:1.45;}
  .modal .actions{ display:flex; gap:8px; justify-content:flex-end; padding: 0 12px 12px; }
  .modal .actions .btn{ flex: 0 0 80px; }
</style>

<!-- For New Visitors -->
<section class="win" id="welcome">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="2" width="8" height="6" fill="#ffd84a" stroke="#000"/></svg></span>
    <span class="t-title"><span>For New Visitors</span><span class="ar">للزوّار الجدد</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        <p>If this is your first time here — welcome. You've landed on the home of Palmetto Studios, a creative studio that uses fashion as its medium.</p>
        <p>What you'll find on the site: the current catalog of essentials, a lookbook, and the studio's ongoing work. New collections drop episodically rather than seasonally — each one a new world rather than a new wardrobe — so the site changes shape over time. What's here today won't be what's here next time.</p>
        <p>If you want the deeper context, the About page covers what the studio is and how it works. Otherwise, take your time, and feel free to write to us if anything catches your eye.</p>
        <p class="signoff">— Palmetto Studios</p>
      </div>
      <div class="col-ar ar">
        <p>إن كانت هذه زيارتك الأولى — أهلاً بك. لقد وصلت إلى موقع ستوديوهات بالميتو، استوديو إبداعي يتّخذ الأزياء وسيطَه.</p>
        <p>ما ستجده هنا: مجموعة الأساسيات الحالية، وكتاب المظهر، والأعمال الجارية للاستوديو. المجموعات الجديدة تصدر على شكل حلقات — كلٌّ منها عالم جديد لا موسم جديد — لذا يتبدّل الموقع شكله مع الوقت. ما هو هنا اليوم ليس بالضرورة ما سيكون هنا غداً.</p>
        <p>إن كنت تبحث عن السياق الأعمق، صفحة "عن الاستوديو" تشرح ما هو وكيف يعمل. وإلا، خذ وقتك، وتجوّل، ولا تتردّد في الكتابة إلينا إن لفتك شيء.</p>
        <p class="signoff" style="font-style:italic;">— ستوديوهات بالميتو</p>
      </div>
    </div>
  </div>
</section>

<!-- About Palmetto Studios -->
<section class="win" id="about">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="1" width="8" height="8" fill="#7d2a2a" stroke="#000"/><rect x="2" y="2" width="6" height="6" fill="#fff"/></svg></span>
    <span class="t-title"><span>About Palmetto Studios</span><span class="ar">عن ستوديوهات بالميتو</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        <p>Palmetto Studios is a creative studio that uses fashion as its primary medium. Its core practice is world-building through art direction and design — each collection is an episode, a self-contained world with its own visual language, references, and lore.</p>
        <p>The studio operates from Saudi Arabia and is built on four ideas that show up in everything it makes: nostalgia, Arabic identity, satire, and playfulness. Drops are thematic rather than seasonal — a new collection is a new world, not a new wardrobe.</p>
        <p>Apparel is where the studio enters, not where it ends. Palmetto is built to expand into objects, collaborations, spaces, and cultural projects.</p>
        <p style="font-family:'Times New Roman',serif; font-size:17px; font-style:italic; margin-top:18px; border-top:1px dashed #b0a890; padding-top:12px;">Most fashion brands sell product. Palmetto sells worlds. The product is how you enter them.</p>
      </div>
      <div class="col-ar ar">
        <p>ستوديوهات بالميتو استوديو إبداعي يتّخذ الأزياء وسيطَه الأساسي. ممارسته الجوهرية هي بناء العوالم عبر الإخراج الفني والتصميم — كل مجموعة حلقة قائمة بذاتها، عالم مستقل بلغته البصرية ومرجعياته وحكاياته.</p>
        <p>يعمل الاستوديو من المملكة العربية السعودية، وقائم على أربع أفكار تتجلّى في كل ما يصنعه: الحنين، والهوية العربية، والسخرية، والمرح. الإصدارات موضوعاتية لا موسمية — كل مجموعة جديدة عالمٌ جديد، لا خزانة ملابس جديدة.</p>
        <p>الأزياء هي مدخل الاستوديو، لا منتهاه. بالميتو مبنيّ ليتوسّع في الأشياء والتعاونات والفضاءات والمشاريع الثقافية.</p>
        <p style="font-size:20px; font-style:italic; margin-top:18px; border-top:1px dashed #b0a890; padding-top:12px;">معظم دور الأزياء تبيع منتجات. بالميتو يبيع عوالم — والمنتج هو بابك إليها.</p>
      </div>
    </div>
  </div>
</section>

<!-- Meaning Behind: Palmetto -->
<section class="win" id="meaning">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><polygon points="5,1 9,5 5,9 1,5" fill="#7d2a2a" stroke="#000"/></svg></span>
    <span class="t-title"><span>Meaning Behind: Palmetto</span><span class="ar">المعنى وراء بالميتو</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        <h3 style="font-size: 34px; line-height:1.05; margin-bottom: 14px;">Meaning Behind:<br>Palmetto</h3>
        <p style="font-size:15px;">The Palmetto Tree is usually a low-growing, fan-leaved palm. The reason for choosing this as a brand name is because it represents the little kid inside of us designing, creating, and innovating through this lens. I aim to introduce playful elements, nostalgia, and a bit of satire in my design ethos, striving to create products that spark a reaction and a sense of belonging.</p>
      </div>
      <div class="col-ar ar">
        <h3 style="font-size: 30px; line-height:1.15; margin-bottom: 14px; font-family:'Amiri',serif; font-weight:700; font-style:normal;">المعنى وراء:<br>بالميتو</h3>
        <p>شجرة البالميتو عادةً نخلةٌ قصيرة بأوراق مروحيّة الشكل. سبب اختيارها اسماً للعلامة هو أنّها تمثّل الطفل الصغير الذي يسكن داخلنا — يصمّم ويبتكر ويُبدع عبر هذه العدسة. أسعى إلى إدخال عناصر مرحة، والحنين، وقدر من السخرية في أسلوبي التصميمي، ساعياً لصنع منتجات تُثير ردّ فعل وإحساساً بالانتماء.</p>
      </div>
    </div>

    <div style="text-align:center; margin: 26px 0 18px;">
      <div style="font-style:italic; font-family:'Times New Roman',serif; font-size:15px; color:#222; margin-bottom: 4px;">
        Wheel of Fortune: Symbol of Wealth in Persian Carpetry
      </div>
      <div class="ar" style="font-size:15px; color:#222; margin-bottom: 12px; direction:rtl;">
        عجلة الحظّ — رمز الوفرة في فنّ السجّاد الفارسي
      </div>
      <div class="ornaments" aria-hidden="true">
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linejoin="miter" stroke-linecap="square">
          <rect x="6" y="6" width="10" height="10"/>
          <rect x="16" y="16" width="10" height="10"/>
          <rect x="26" y="6" width="10" height="10"/>
          <rect x="6" y="26" width="10" height="10"/>
          <rect x="26" y="26" width="10" height="10"/>
          <line x1="11" y1="16" x2="11" y2="26"/>
          <line x1="31" y1="16" x2="31" y2="26"/>
          <line x1="16" y1="11" x2="26" y2="11"/>
          <line x1="16" y1="31" x2="26" y2="31"/>
        </svg>
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" stroke="#1a1a1a" stroke-width="2">
          <rect x="6" y="22" width="30" height="14"/>
          <rect x="10" y="14" width="22" height="8"/>
          <rect x="14" y="6" width="14" height="8"/>
          <line x1="13" y1="22" x2="13" y2="36"/>
          <line x1="21" y1="22" x2="21" y2="36"/>
          <line x1="29" y1="22" x2="29" y2="36"/>
        </svg>
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linejoin="miter">
          <polygon points="21,4 26,16 38,21 26,26 21,38 16,26 4,21 16,16"/>
          <line x1="16" y1="16" x2="26" y2="26"/>
          <line x1="26" y1="16" x2="16" y2="26"/>
        </svg>
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" stroke="#1a1a1a" stroke-width="2">
          <line x1="21" y1="4" x2="21" y2="38"/>
          <line x1="4" y1="21" x2="38" y2="21"/>
          <circle cx="21" cy="8" r="3"/>
          <circle cx="21" cy="34" r="3"/>
          <circle cx="8" cy="21" r="3"/>
          <circle cx="34" cy="21" r="3"/>
          <circle cx="21" cy="21" r="4"/>
        </svg>
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" stroke="#1a1a1a" stroke-width="2">
          <circle cx="21" cy="21" r="17"/>
          <circle cx="21" cy="21" r="13"/>
          <circle cx="21" cy="21" r="9"/>
          <circle cx="21" cy="21" r="5"/>
          <circle cx="21" cy="21" r="1.5" fill="#1a1a1a"/>
        </svg>
      </div>
    </div>

    <div class="two-col">
      <div class="col-en">
        <p style="font-size:15px;">The new logo is inspired by the ornaments of a Persian rug. The spiral shape in these ornaments often symbolizes the blessing of wealth and abundance. Hopefully, my brand will give you that feeling of blessing and importance.</p>
        <p class="signoff">— Palmetto Studios</p>
      </div>
      <div class="col-ar ar">
