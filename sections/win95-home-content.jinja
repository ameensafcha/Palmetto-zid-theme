<!-- The Carpets -->
<section class="win" id="carpets">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="2" width="8" height="6" fill="#7d2a2a" stroke="#000"/><line x1="1" y1="4" x2="9" y2="4" stroke="#fff"/><line x1="1" y1="6" x2="9" y2="6" stroke="#fff"/></svg></span>
    <span class="t-title"><span>{{ settings.carpets_title | default("The Carpets") }}</span><span class="ar">{{ settings.carpets_title_ar | default("\u0627\u0644\u0633\u062c\u0651\u0627\u062f") }}</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        <h3 style="margin-bottom:10px;">{{ settings.carpets_title | default("The Carpets") }}</h3>
        <p>{{ settings.carpets_intro_en | default("A small collection of carpet designs by the studio — woven, room-scale, made to order. Each piece carries its own concept. If something catches you, write to us and we'll take it from there.") }}</p>
      </div>
      <div class="col-ar ar" style="font-size:15px; line-height:1.6;">
        <h3 style="margin-bottom:10px; font-family:'Amiri',serif; font-weight:700;">{{ settings.carpets_title_ar | default("\u0627\u0644\u0633\u062c\u0651\u0627\u062f") }}</h3>
        <p>{{ settings.carpets_intro_ar | default("مجموعة من تصاميم السجّاد من الاستوديو — منسوجة، بحجم الغرفة، تُصنع حسب الطلب. كل قطعة تحمل مفهومها الخاص. إن لفتك واحدة منها، اكتب إلينا وسنأخذ الأمر من هناك.") }}</p>
      </div>
    </div>

    {% set carpets = settings.carpets | default([]) %}

    {% macro carpet_card(carpet, is_wide) %}
      {% set views = [] %}
      {% if carpet.img_1 %}{% set views = views + [carpet.img_1] %}{% endif %}
      {% if carpet.img_2 %}{% set views = views + [carpet.img_2] %}{% endif %}
      {% if carpet.img_3 %}{% set views = views + [carpet.img_3] %}{% endif %}
      {% set name = carpet.name | default("Carpet") %}
      <article class="carpet-card{% if is_wide %} wide{% endif %}">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>{{ name }}</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        {% if is_wide %}<div class="body-row">{% endif %}
        <div class="img"{% if views %} data-views="{{ views | join('|') }}"{% endif %}>
          {% if views %}
            {% for v in views %}
              {% if loop.first %}
            <img src="{{ v }}" class="prod-img" alt="{{ name }}" decoding="async" loading="eager">
              {% else %}
            <img src="{{ v }}" class="prod-img" alt="{{ name }}" style="position:absolute;inset:0;opacity:0;transition:opacity 80ms linear;pointer-events:none;" decoding="async" loading="eager">
              {% endif %}
            {% endfor %}
          {% else %}
          <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.5);"></div>
          <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">{{ name | lower | replace(" ", "-") }}.jpg</div>
          {% endif %}
        </div>
        {% if is_wide %}<div class="body">{% else %}<div class="body">{% endif %}
          <div class="head"><div class="name">{{ name }}</div><div class="dim">{{ carpet.dim | default("") }}</div></div>
          <p class="desc-en">{{ carpet.desc_en | default("") }}</p>
          <p class="desc-ar">{{ carpet.desc_ar | default("") }}</p>
        </div>
        {% if is_wide %}</div>{% endif %}
      </article>
    {% endmacro %}

    {% if carpets | length > 0 %}

    <div class="carpets-grid">
    {% for carpet in carpets %}
      {% if not carpet.wide %}
        {{ carpet_card(carpet, false) }}
      {% endif %}
    {% endfor %}
    </div>

    {% set wide_carpets = carpets | selectattr("wide") | list %}
    {% if wide_carpets | length > 0 %}
    <div class="carpets-bottom-row">
    {% for carpet in wide_carpets %}
      {{ carpet_card(carpet, true) }}
    {% endfor %}
    </div>
    {% endif %}

    {% else %}

    <div class="carpets-grid">

      <article class="carpet-card">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>Serenity Carpet</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        <div class="img">
          <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.5);"></div>
          <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">serenity-carpet.jpg</div>
        </div>
        <div class="body">
          <div class="head"><div class="name">Serenity Carpet</div><div class="dim">240 × 160 cm</div></div>
          <p class="desc-en">A Persian carpet field invaded by atomic orbits, hazard triangles, and Y2K detritus. The borders repeat a single phrase: "Running through space and time just to find serenity."</p>
          <p class="desc-ar">حقل سجّاد فارسي يقتحمه مدارات ذرّية ومثلّثات تحذير وبقايا حقبة الألفيّة. على الحدود عبارة واحدة تتكرّر: "Running through space and time just to find serenity".</p>
        </div>
      </article>

      <article class="carpet-card">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>3bsi is Alive</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        <div class="img" style="background: repeating-linear-gradient(135deg,#1d1d1d 0 8px,#2a2a2a 8px 16px);">
          <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.4);"></div>
          <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">3bsi-is-alive.jpg</div>
        </div>
        <div class="body">
          <div class="head"><div class="name">3bsi is Alive</div><div class="dim">240 × 160 cm</div></div>
          <p class="desc-en">A Khaleeji folk figure who refused his exit — skeleton in a ghutra, lamp in one hand, bones in the other, attended by teeth, jewels, and crescent moons.</p>
          <p class="desc-ar">شخصيّة خليجيّة شعبيّة رفضت خروجها — هيكل عظمي بشماغ، فانوس في يدٍ وعظام في الأخرى، يحفّ به أسنان وجواهر وأهلّة.</p>
        </div>
      </article>

      <article class="carpet-card">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>Shapes and Ladders</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        <div class="img" style="background: repeating-linear-gradient(135deg,#1a1a1a 0 8px,#2d2d2d 8px 16px);">
          <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.4);"></div>
          <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">shapes-and-ladders.jpg</div>
        </div>
        <div class="body">
          <div class="head"><div class="name">Shapes and Ladders</div><div class="dim">140 × 220 cm</div></div>
          <p class="desc-en">A high-contrast monochrome field of folk silhouettes — horse, cherries, palm, crescent, dancer — stitched into a rebus that reads like a board game.</p>
          <p class="desc-ar">حقل أحادي اللون عالي التباين، ملّف بظلال شعبيّة — حصان، كرز، نخلة، هلال، راقص — تتجمّع كأنّها لوحة لعبة.</p>
        </div>
      </article>

    </div>

    <div class="carpets-bottom-row">

      <article class="carpet-card wide">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>Arcadia</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        <div class="body-row">
          <div class="img" style="background: repeating-linear-gradient(45deg,#274b3b 0 8px,#2f5a47 8px 16px);">
            <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.5);"></div>
            <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">arcadia.jpg</div>
          </div>
          <div class="body">
            <div class="head"><div class="name">Arcadia</div><div class="dim">140 × 220 cm</div></div>
            <p class="desc-en">A pixel-rendered Persian carpet interrupted by a 1990s UFO. Classical pastoral form, briefly abducted.</p>
            <p class="desc-ar">سجّادة فارسيّة بأسلوب البكسل، يقطعها صحن طائر تسعينيّ. شكل رعويّ كلاسيكيّ، يُختطف لحظة.</p>
          </div>
        </div>
      </article>

      <article class="carpet-card wide">
        <div class="titlebar"><span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="3" fill="none" stroke="#fff"/></svg></span><span class="t-title"><span>Palmetto Monogram</span></span><span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span></div>
        <div class="body-row">
          <div class="img" style="background: repeating-linear-gradient(45deg,#5b4322 0 8px,#6a4f29 8px 16px);">
            <div style="position:absolute; inset:14px; border:1px dashed rgba(255,255,255,.5);"></div>
            <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-family:'Courier New',monospace; font-size:10px; color:#fffef7; background:rgba(0,0,0,.55); padding:3px 8px; border:1px dashed #fffef7; letter-spacing:1px;">palmetto-monogram.jpg</div>
          </div>
          <div class="body">
            <div class="head"><div class="name">Palmetto Monogram</div><div class="dim">140 × 220 cm</div></div>
            <p class="desc-en">A monogram in the European luxury tradition — palm trees, dallah, geometric tile, the national emblem. Khaleeji vocabulary in luxury's clothing.</p>
            <p class="desc-ar">مونوغرام في تقليد دور الأزياء الأوروبيّة — نخيل، دلال، زليج هندسي، الشعار الوطني. مفردات خليجيّة بلباس الترف.</p>
          </div>
        </div>
      </article>

    </div>

    {% endif %}

    <div class="two-col" style="margin-top:22px; padding-top:14px; border-top:1px dashed #b0a890;">
      <div class="col-en">
        <p style="margin:0;">{{ settings.carpets_cta_en | default("Made to order. Inquire at <a href=\"mailto:palmetto.sa@gmail.com\">palmetto.sa@gmail.com</a>.") }}</p>
        {% if settings.carpets_signoff_en is defined and settings.carpets_signoff_en %}<p class="signoff" style="margin-top:6px;">{{ settings.carpets_signoff_en }}</p>{% endif %}
      </div>
      <div class="col-ar ar" style="font-size:15px; line-height:1.5;">
        <p style="margin:0;">{{ settings.carpets_cta_ar | default("تُصنع حسب الطلب. للاستفسار: palmetto.sa@gmail.com") }}</p>
        {% if settings.carpets_signoff_ar is defined and settings.carpets_signoff_ar %}<p class="signoff" style="font-style:italic; margin-top:6px;">{{ settings.carpets_signoff_ar }}</p>{% endif %}
      </div>
    </div>
  </div>
</section>

