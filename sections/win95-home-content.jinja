<!-- Contact -->
<section class="win" id="contact">
  <div class="titlebar">
    <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="2" width="8" height="3" rx="1" fill="#222" stroke="#000"/><rect x="1" y="5" width="8" height="3" fill="#ddd" stroke="#000"/></svg></span>
    <span class="t-title"><span>{{ settings.contact_title_en | default("Contact") }}</span><span class="ar">{{ settings.contact_title_ar | default("التواصل") }}</span></span>
    <span class="tb-btn">_</span><span class="tb-btn">▢</span><span class="tb-btn">✕</span>
  </div>
  <div class="panel">
    <div class="two-col">
      <div class="col-en">
        {% if settings.contact_intro_en is defined and settings.contact_intro_en %}<p style="margin-top:0;">{{ settings.contact_intro_en }}</p>{% endif %}
        <div class="contact-grid" style="grid-template-columns:1fr;">
          <div class="field-row" style="grid-template-columns:90px 1fr;">
            <div class="lbl">Email:</div>
            <div class="val"><a href="mailto:{{ settings.contact_email | default('palmetto.sa@gmail.com') }}">{{ settings.contact_email | default('palmetto.sa@gmail.com') }}</a></div>
          </div>
          <div class="field-row" style="grid-template-columns:90px 1fr;">
            <div class="lbl">Instagram:</div>
            <div class="val"><a href="{{ settings.contact_instagram | default('https://instagram.com/palmetto.studios') }}" target="_blank" rel="noopener">{{ settings.contact_instagram | default('https://instagram.com/palmetto.studios') | replace("https://instagram.com/", "@") }}</a></div>
          </div>
          <div class="field-row" style="grid-template-columns:90px 1fr;">
            <div class="lbl">Studio:</div>
            <div class="val">{{ settings.contact_studio_en | default("Khobar, Saudi Arabia") }}</div>
          </div>
        </div>
        {% if settings.contact_signoff_en is defined and settings.contact_signoff_en %}<p class="signoff">{{ settings.contact_signoff_en }}</p>{% endif %}
      </div>
      <div class="col-ar ar">
        {% if settings.contact_intro_ar is defined and settings.contact_intro_ar %}<p style="margin-top:0;">{{ settings.contact_intro_ar }}</p>{% endif %}
        <div class="contact-grid" style="grid-template-columns:1fr; direction:rtl;">
          <div class="field-row" style="grid-template-columns:120px 1fr;">
            <div class="lbl" style="text-align:left;">البريد الإلكتروني:</div>
            <div class="val">{{ settings.contact_email | default('palmetto.sa@gmail.com') }}</div>
          </div>
          <div class="field-row" style="grid-template-columns:120px 1fr;">
            <div class="lbl" style="text-align:left;">إنستغرام:</div>
            <div class="val">{{ settings.contact_instagram | default('https://instagram.com/palmetto.studios') | replace("https://instagram.com/", "@") }}</div>
          </div>
          <div class="field-row" style="grid-template-columns:120px 1fr;">
            <div class="lbl" style="text-align:left;">الاستوديو:</div>
            <div class="val">{{ settings.contact_studio_ar | default("\u0627\u0644\u062e\u0628\u0631\u060c \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629") }}</div>
          </div>
        </div>
        {% if settings.contact_signoff_ar is defined and settings.contact_signoff_ar %}<p class="signoff" style="font-style:italic;">{{ settings.contact_signoff_ar }}</p>{% endif %}
      </div>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="modal-veil" id="lightbox-veil" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
  <div class="modal" style="width: min(720px, 94vw);">
    <div class="titlebar">
      <span class="tb-btn"><svg width="10" height="10" viewBox="0 0 10 10"><rect x="1" y="1" width="8" height="8" fill="#fff" stroke="#000"/><circle cx="5" cy="5" r="2" fill="none" stroke="#000"/></svg></span>
      <span class="t-title" id="lightbox-title">Image Viewer</span>
      <span class="tb-btn" data-close-lb>_</span>
      <span class="tb-btn" data-close-lb>▢</span>
      <span class="tb-btn" data-close-lb>✕</span>
    </div>
    <div style="padding: 8px; background: var(--chrome);">
      <div style="background:#fffef7; border-style:solid; border-width:2px; border-color: var(--lo) var(--hi) var(--hi) var(--lo); padding:6px;">
        <img id="lightbox-img" src="" alt="" style="display:block; width:100%; height:auto; max-height: 70vh; object-fit: contain;">
      </div>
      <div id="lightbox-cap" style="font-family:'Times New Roman',serif; font-size:14px; padding: 8px 4px 2px; display:flex; justify-content:space-between; align-items:baseline; gap:10px;">
        <span></span><span class="mono" style="font-family:'Courier New',monospace; font-size:12px; color:#444;"></span>
      </div>
    </div>
    <div class="actions"><button class="btn primary" data-close-lb>Close</button></div>
  </div>
</div>

<script>
console.log('=== CARPET SECTION DEBUG ===');
document.querySelectorAll('.carpet-card').forEach(function(c, i){
  console.log('Carpet ' + i + ':', c.querySelector('.name') ? c.querySelector('.name').textContent.trim() : 'no name');
  var img = c.querySelector('.img');
  console.log('  data-views:', img ? img.dataset.views : 'no img');
  console.log('  imgs found:', img ? img.querySelectorAll('img').length : 0);
});
document.querySelectorAll('.carpet-card .img[data-views]').forEach(function(box){
  var first = box.querySelector('img');
  if (!first) return;
  var views = box.dataset.views.split('|');
  var imgs = views.map(function(u, idx){
    var im = (idx === 0) ? first : document.createElement('img');
    im.src = u; im.className = 'prod-img'; im.alt = first.alt || '';
    im.style.position='absolute'; im.style.inset='0';
    im.style.opacity = (idx === 0) ? '1' : '0';
    im.style.transition = 'opacity 80ms linear';
    im.style.pointerEvents = 'none';
    im.decoding='async'; im.loading='eager';
    if (idx !== 0) box.appendChild(im);
    return im;
  });
  var i = 0;
  var counter = document.createElement('div');
  counter.className = 'view-count';
  counter.textContent = '1/' + views.length;
  box.appendChild(counter);
  function go(d){
    var p = i;
    i = (i + d + views.length) % views.length;
    imgs[i].style.opacity='1';
    imgs[p].style.opacity='0';
    counter.textContent = (i+1) + '/' + views.length;
  }
  var pb = document.createElement('button');
  pb.type='button'; pb.className='nav-arrow prev'; pb.setAttribute('aria-label','Previous view'); pb.textContent='◀';
  var nb = document.createElement('button');
  nb.type='button'; nb.className='nav-arrow next'; nb.setAttribute('aria-label','Next view'); nb.textContent='▶';
  pb.addEventListener('click', function(e){ e.stopPropagation(); go(-1); });
  nb.addEventListener('click', function(e){ e.stopPropagation(); go(1); });
  box.appendChild(pb); box.appendChild(nb);
});

var lb = document.getElementById('lightbox-veil');
var lbImg = document.getElementById('lightbox-img');
var lbTitle = document.getElementById('lightbox-title');
var lbCap = document.getElementById('lightbox-cap');

document.querySelectorAll('.carpet-card .img').forEach(function(box){
  box.insertAdjacentHTML('beforeend', '<span class="zoom-hint">click to enlarge</span>');
  box.addEventListener('click', function(e){
    if (e.target.closest('.nav-arrow')) return;
    var card = box.closest('.carpet-card');
    var name = card.querySelector('.name').textContent.trim();
    var dim = card.querySelector('.dim') ? card.querySelector('.dim').textContent.trim() : '';
    var imgs = box.querySelectorAll('img');
    var img = null;
    imgs.forEach(function(im){ if (im.style.opacity !== '0') img = im; });
    if (!img) img = imgs[0];
    if (!img) return;
    lbImg.src = img.src;
    lbImg.alt = img.alt || name;
    lbTitle.textContent = name + (dim ? ' — ' + dim : '');
    lbCap.children[0].textContent = name + (dim ? ' — ' + dim : '');
    lbCap.children[1].textContent = (img.src.split('/').pop());
    lb.classList.add('open');
  });
});

lb.addEventListener('click', function(e){
  if (e.target === lb || e.target.matches('[data-close-lb]')) lb.classList.remove('open');
});
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape') lb.classList.remove('open');
});
</script>
{% endif %}
