        {% if settings.returns_p2_ar is defined and settings.returns_p2_ar %}<p>{{ settings.returns_p2_ar }}</p>{% endif %}
        {% if settings.returns_p3_ar is defined and settings.returns_p3_ar %}<p>{{ settings.returns_p3_ar }}</p>{% endif %}
