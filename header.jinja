<style>
  .raise {
    border-style: solid;
    border-width: 2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
    background: var(--chrome);
  }
  .inset {
    border-style: solid;
    border-width: 2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    box-shadow: inset 1px 1px 0 var(--lo-2), inset -1px -1px 0 var(--hi-2);
    background: var(--chrome);
  }
  .field {
    background: var(--paper);
    border-style: solid;
    border-width: 2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    box-shadow: inset 1px 1px 0 var(--lo-2), inset -1px -1px 0 var(--hi-2);
  }
  .btn {
    flex: 1;
    background: var(--chrome);
    border-style: solid;
    border-width: 2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
    padding: 4px 8px;
    font-family: "Tahoma", sans-serif;
    font-size: 11px;
    color: #000;
    cursor: default;
    text-align: center;
  }
  .btn:hover{ filter:brightness(1.02);}
  .btn:active {
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    box-shadow: inset 1px 1px 0 var(--lo-2), inset -1px -1px 0 var(--hi-2);
    padding: 5px 7px 3px 9px;
  }
  .btn.primary { font-weight: 700; }

  /* Alert Ribbon */
  .alert-ribbon {
    max-width: 960px;
    width: 96vw;
    margin: 18px auto 14px;
    display: flex;
    align-items: stretch;
    background: var(--warn-yellow);
    border-style: solid;
    border-width: 2px;
    border-color: #000;
    box-shadow: 2px 2px 0 rgba(0,0,0,.3);
    overflow: hidden;
    height: 34px;
  }
  .alert-ribbon .bang {
    background: #000;
    color: var(--warn-yellow);
    font-weight: 900;
    font-size: 18px;
    display: grid;
    place-items: center;
    width: 34px;
    flex: 0 0 34px;
    border-right: 2px solid #000;
    font-family: "Times New Roman", serif;
  }
  .alert-ribbon .marq {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  .alert-ribbon .marq-inner {
    display: flex;
    gap: 60px;
    white-space: nowrap;
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    animation: marquee 32s linear infinite;
    padding-left: 100%;
  }
  .alert-ribbon .marq-inner span.ar{ font-size:16px; line-height:1; }
  .alert-ribbon .marq-inner span {
    font-weight: 700;
    font-size: 13px;
    color: #000;
  }
  .alert-ribbon .blink { animation: blink 1.1s steps(2,end) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  @keyframes marquee {
    from { transform: translate(0%, -50%); }
    to { transform: translate(-50%, -50%); }
  }

  /* Main Window */
  .win {
    background: var(--chrome);
    border-style: solid;
    border-width: 2px;
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo), 2px 2px 0 rgba(0,0,0,.25);
    margin: 0 auto;
    max-width: 960px;
    width: 96vw;
  }
  .titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 22px;
    padding: 0 3px 0 4px;
    background: linear-gradient(90deg, var(--tb-1) 0%, var(--tb-2) 100%);
    color: #fff;
    font-weight: 700;
    font-size: 12px;
    user-select: none;
  }
  .titlebar .t-title { 
    flex: 1; 
    display: flex; 
    gap: 10px; 
    align-items: center; 
    min-width: 0; 
    overflow: hidden; 
    white-space: nowrap; 
    text-overflow: ellipsis;
  }
  .titlebar .tb-btn {
    width: 18px;
    height: 16px;
    display: grid;
    place-items: center;
    background: var(--chrome);
    border-color: var(--hi) var(--lo-2) var(--lo-2) var(--hi);
    border-style: solid;
    border-width: 1px;
    box-shadow: inset 1px 1px 0 var(--hi-2), inset -1px -1px 0 var(--lo);
    color: #000;
    font-family: "Marlett","Tahoma",sans-serif;
    font-size: 10px;
    font-weight: 700;
    cursor: default;
  }
  .titlebar .tb-btn svg { display: block; }

  .menubar {
    display: flex;
    gap: 0;
    padding: 2px 4px;
    border-bottom: 1px solid var(--lo);
    background: var(--chrome);
    font-size: 11px;
  }
  .menubar span { padding: 2px 7px; cursor: default; }
  .menubar span:hover { background: var(--tb-1); color: #fff; }

  .statusbar {
    display: flex;
    gap: 4px;
    padding: 3px;
    border-top: 1px solid var(--hi);
  }
  .statusbar .cell {
    flex: 1;
    padding: 2px 6px;
    border-style: solid;
    border-width: 1px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    font-size: 11px;
  }
  .statusbar .cell.fixed { flex: 0 0 auto; min-width: 80px; text-align: center; }

  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 14px;
    align-items: center;
    padding: 14px 16px 8px;
  }
  .hero .palm {
    width: 96px;
    height: 96px;
    border: 2px solid #000;
    background: repeating-linear-gradient(45deg, #f1ead2 0 6px, #e9e0bf 6px 12px);
    display: grid;
    place-items: center;
    box-shadow: inset 0 0 0 4px #fffef7;
  }
  .hero .palm .glyph {
    font-family: "Times New Roman", serif;
    font-style: italic;
    font-weight: 700;
    font-size: 46px;
    line-height: 1;
    color: #1d1d1d;
  }
  .hero .wordmark { text-align: center; }
  .hero .wordmark .en {
    font-family: "Times New Roman", serif;
    font-size: 38px;
    font-weight: 700;
    letter-spacing: .5px;
    line-height: 1;
  }
  .hero .wordmark .ar{
    font-size:22px; margin-top:6px; line-height:1;
  }
  .hero .wordmark .tag {
    margin-top: 10px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .hero .clock { text-align: right; }
  .hero .clock .lcd {
    display: inline-block;
    background: #000;
    color: #0f0;
    font-family: "Courier New", monospace;
    font-weight: 700;
    font-size: 14px;
    padding: 4px 8px;
    border-style: solid;
    border-width: 2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
  }
  .hero .clock .vis {
    margin-top: 6px;
    font-size: 11px;
    color: #000;
  }
  .hero .clock .vis b { font-family: "Courier New", monospace; }

  /* Icon Grid */
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 6px;
    padding: 10px 12px 14px;
  }
  .icon-grid .ic {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 8px 4px 10px;
    cursor: default;
    text-decoration: none;
    color: #000;
    border: 1px dotted transparent;
  }
  .icon-grid .ic:hover { border: 1px dotted #000; background: rgba(0,0,128,.08); }
  .icon-grid .ic:active, .icon-grid .ic.active {
    background: var(--tb-1);
    color: #fff;
    border: 1px dotted #fff;
  }
  .icon-grid .ic:active .lbl, .icon-grid .ic.active .lbl { color: #fff; }
  .icon-grid .ic .ribbon{
    position:absolute; top:-2px; right:2px;
    background:var(--warn-yellow);
    border:1px solid #000;
    color:#b00000; font-weight:900; font-size:10px;
    padding: 1px 4px;
    transform: rotate(8deg);
    box-shadow: 1px 1px 0 rgba(0,0,0,.3);
  }
  .icon-grid .ic .art {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
  }
  .icon-grid .ic .lbl {
    font-size: 11px;
    text-align: center;
    line-height: 1.15;
    color: #000;
    text-shadow: 1px 1px 0 rgba(255,255,255,.6);
  }

  /* Link Row */
  .linkrow {
    background: #fff;
    border-style: solid;
    border-width: 2px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    margin: 4px 12px 12px;
    padding: 8px 10px;
    text-align: center;
    font-family: "Times New Roman", serif;
    font-size: 14px;
  }
  .linkrow a { font-weight: 700; }
  .linkrow .sep { color: #000; margin: 0 6px; }
  .linkrow.ar{ direction:rtl; font-size:16px; padding-top:6px; padding-bottom:6px; margin-top:-6px;}

  .statusbar{
    display:flex; gap:4px; padding:3px;
    border-top:1px solid var(--hi);
  }
  .statusbar .cell{
    flex:1; padding: 2px 6px;
    border-style:solid; border-width:1px;
    border-color: var(--lo) var(--hi) var(--hi) var(--lo);
    font-size:11px;
  }
  .statusbar .cell.fixed{ flex:0 0 auto; min-width:80px; text-align:center;}

  @media (max-width: 760px) {
    .icon-grid { grid-template-columns: repeat(4, 1fr); }
    .hero { grid-template-columns: 1fr; gap: 8px; }
    .hero .clock, .hero .palm { justify-self: center; }
    .hero .clock { text-align: center; }
  }
</style>

